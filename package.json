    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "msw": "^2.14.2",
    "react": "^19.2.5",
    "react-activity-calendar": "^3.2.0",
    "react-big-calendar": "^1.19.4",
    "react-calendar-heatmap": "^1.10.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.5.0",
